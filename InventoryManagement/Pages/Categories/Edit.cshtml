@page "{id:int}"
@model InventoryManagement.Pages.Categories.EditModel
@{
    ViewData["Title"] = $"Edit — {Model.Category.Name}";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a asp-page="Index">Categories</a></li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
        <h1>Edit Category</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <form method="post">
            <input type="hidden" asp-for="Category.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-4"></div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Category Details</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Category.Name" class="form-label"></label>
                        <input asp-for="Category.Name" class="form-control" />
                        <span asp-validation-for="Category.Name" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Category.Description" class="form-label"></label>
                        <textarea asp-for="Category.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Category.Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Products in this category -->
            @if (Model.ProductCount > 0)
            {
                <div class="alert alert-info small mb-4">
                    <i class="bi bi-info-circle me-1"></i>
                    This category contains <strong>@Model.ProductCount product@(Model.ProductCount == 1 ? "" : "s")</strong>.
                    Renaming it will update the category name across all linked products.
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                @if (Model.ProductCount == 0)
                {
                    <a asp-page="Delete" asp-route-id="@Model.Category.Id"
                       class="btn btn-outline-danger ms-auto">
                        <i class="bi bi-trash me-1"></i> Delete
                    </a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
