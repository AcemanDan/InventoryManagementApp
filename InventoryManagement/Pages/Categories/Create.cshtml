@page
@model InventoryManagement.Pages.Categories.CreateModel
@{
    ViewData["Title"] = "Add Category";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a asp-page="Index">Categories</a></li>
                <li class="breadcrumb-item active">Add Category</li>
            </ol>
        </nav>
        <h1>Add Category</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-4"></div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Category Details</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Category.Name" class="form-label"></label>
                        <input asp-for="Category.Name" class="form-control"
                               placeholder="e.g. Electronics" autofocus />
                        <span asp-validation-for="Category.Name" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Category.Description" class="form-label"></label>
                        <textarea asp-for="Category.Description" class="form-control" rows="3"
                                  placeholder="Optional description…"></textarea>
                        <span asp-validation-for="Category.Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Category
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
