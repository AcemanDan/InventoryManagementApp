@page
@model InventoryManagement.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div class="page-header">
    <h1><i class="bi bi-tags me-2 text-primary"></i>Categories</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Category
    </a>
</div>

@if (Model.Categories.Any())
{
    <div class="row g-3">
        @foreach (var c in Model.Categories)
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:38px;height:38px;background:#f0f4ff;">
                                    <i class="bi bi-tag-fill text-primary"></i>
                                </div>
                                <h6 class="fw-bold mb-0">@c.Name</h6>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light border-0 px-2"
                                        data-bs-toggle="dropdown" aria-label="Actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    <li>
                                        <a class="dropdown-item small"
                                           asp-page="/Products/Index" asp-route-categoryId="@c.Id">
                                            <i class="bi bi-box-seam me-2"></i>View Products
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item small" asp-page="Edit" asp-route-id="@c.Id">
                                            <i class="bi bi-pencil me-2"></i>Edit
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <a class="dropdown-item small text-danger"
                                           asp-page="Delete" asp-route-id="@c.Id">
                                            <i class="bi bi-trash me-2"></i>Delete
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <p class="text-muted small mb-3 text-truncate">@c.Description</p>
                        }
                        else
                        {
                            <p class="text-muted small mb-3 fst-italic">No description</p>
                        }

                        <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top">
                            <span class="small text-muted">
                                <i class="bi bi-box-seam me-1"></i>
                                <strong>@c.ProductCount</strong> product@(c.ProductCount == 1 ? "" : "s")
                            </span>
                            <a asp-page="/ProductPages/Index" asp-route-categoryId="@c.Id"
                               class="btn btn-sm btn-outline-primary @(c.ProductCount == 0 ? "disabled" : "")">
                                View <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-tags display-4 d-block mb-3 opacity-25"></i>
            <p class="fw-semibold mb-1">No categories yet</p>
            <p class="small mb-3">Add a category to start organizing your products.</p>
            <a asp-page="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Category
            </a>
        </div>
    </div>
}

