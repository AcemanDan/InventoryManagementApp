@page
@model InventoryManagement.Pages.Admin.ProfileModel
@{
    ViewData["Title"] = "Profile";
}

<div class="page-header">
    <h1><i class="bi bi-person-circle me-2 text-primary"></i>Admin Profile</h1>
</div>

<div class="row">
    <div class="col-lg-8">

        <!-- ── Profile form ───────────────────────────────────────────────── -->
        <form method="post" asp-page-handler="Profile">
            <input type="hidden" asp-for="Profile.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-4"></div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-person me-2 text-primary"></i>Personal Information
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Profile.FirstName" class="form-label"></label>
                            <input asp-for="Profile.FirstName" class="form-control"
                                   placeholder="First name" />
                            <span asp-validation-for="Profile.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Profile.LastName" class="form-label"></label>
                            <input asp-for="Profile.LastName" class="form-control"
                                   placeholder="Last name" />
                            <span asp-validation-for="Profile.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="Profile.Email" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Profile.Email" class="form-control"
                                       placeholder="admin@example.com" />
                            </div>
                            <span asp-validation-for="Profile.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Profile.Phone" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input asp-for="Profile.Phone" class="form-control"
                                       placeholder="555-0100" />
                            </div>
                            <span asp-validation-for="Profile.Phone" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Profile.JobTitle" class="form-label"></label>
                        <input asp-for="Profile.JobTitle" class="form-control"
                               placeholder="e.g. Warehouse Manager" />
                        <span asp-validation-for="Profile.JobTitle" class="text-danger small"></span>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Profile.Bio" class="form-label"></label>
                        <textarea asp-for="Profile.Bio" class="form-control" rows="3"
                                  placeholder="A short bio…"></textarea>
                        <span asp-validation-for="Profile.Bio" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 align-items-center mb-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Profile
                </button>
                <span class="text-muted small">
                    Last updated: @Model.Profile.LastUpdated.ToString("MMM d, yyyy h:mm tt")
                </span>
            </div>
        </form>

        <!-- ── Password change form ───────────────────────────────────────── -->
        <form method="post" asp-page-handler="Password">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-shield-lock me-2 text-primary"></i>Change Password
                </div>
                <div class="card-body">
                    @if (TempData["PasswordError"] is string pwdErr)
                    {
                        <div class="alert alert-danger small">@pwdErr</div>
                    }
                    <div class="mb-3">
                        <label asp-for="Profile.CurrentPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Profile.CurrentPassword" class="form-control"
                                   id="currentPwd" placeholder="Enter current password" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('currentPwd',this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Profile.NewPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Profile.NewPassword" class="form-control"
                                   id="newPwd" placeholder="Min. 8 characters" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('newPwd',this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Profile.NewPassword" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Profile.ConfirmPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Profile.ConfirmPassword" class="form-control"
                                   id="confirmPwd" placeholder="Repeat new password" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePwd('confirmPwd',this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Profile.ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-outline-primary">
                <i class="bi bi-shield-check me-1"></i> Update Password
            </button>
        </form>
    </div>

    <!-- ── Avatar sidebar ── -->
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm mb-3 text-center p-4">
            <!-- Avatar initials -->
            <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center fw-bold text-white fs-2"
                 style="width:90px;height:90px;background:#0d6efd;">
                @(Model.Profile.FirstName.Length > 0 ? Model.Profile.FirstName[0].ToString() : "A")@(Model.Profile.LastName.Length > 0 ? Model.Profile.LastName[0].ToString() : "")
            </div>
            <h6 class="fw-bold mb-0">@Model.Profile.FullName</h6>
            @if (!string.IsNullOrEmpty(Model.Profile.JobTitle))
            {
                <p class="text-muted small mb-1">@Model.Profile.JobTitle</p>
            }
            <p class="text-muted small mb-0">
                <i class="bi bi-envelope me-1"></i>@Model.Profile.Email
            </p>
            @if (!string.IsNullOrEmpty(Model.Profile.Bio))
            {
                <p class="text-muted small mt-2 mb-0 fst-italic">@Model.Profile.Bio</p>
            }
        </div>

        <!-- Password strength tips -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Password Tips</div>
            <div class="card-body small text-muted">
                <ul class="ps-3 mb-0">
                    <li>At least <strong>8 characters</strong></li>
                    <li>Mix uppercase and lowercase letters</li>
                    <li>Include at least one number</li>
                    <li>Use a special character (!, @@, #…)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon  = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
    }

