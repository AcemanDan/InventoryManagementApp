@page
@model InventoryManagement.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- ── Summary Cards ── -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-primary">
            <div class="card-body">
                <p class="small text-white-50 mb-1">Total Products</p>
                <h3 class="fw-bold mb-0">@Model.TotalProducts</h3>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-success">
            <div class="card-body">
                <p class="small text-white-50 mb-1">Total Stock Units</p>
                <h3 class="fw-bold mb-0">@Model.TotalStock.ToString("N0")</h3>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-warning">
            <div class="card-body">
                <p class="small text-white-50 mb-1">Low Stock Items</p>
                <h3 class="fw-bold mb-0">@Model.LowStockCount</h3>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm text-white bg-info">
            <div class="card-body">
                <p class="small text-white-50 mb-1">Active Suppliers</p>
                <h3 class="fw-bold mb-0">@Model.ActiveSuppliers</h3>
            </div>
        </div>
    </div>
</div>

<!-- ── Charts Row ── -->
<div class="row g-4 mb-4">
    <!-- Stock by Category (Bar) -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">Stock by Category</div>
            <div class="card-body">
                <canvas id="stockByCategoryChart" height="260"></canvas>
            </div>
        </div>
    </div>

    <!-- Products per Category (Doughnut) -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">Products per Category</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="productsByCategoryChart" height="260"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ── Low Stock Alerts Table ── -->
@if (Model.LowStockProducts.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent fw-semibold text-danger">
            <i class="bi bi-exclamation-triangle-fill me-1"></i> Low Stock Alerts
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th class="text-end">In Stock</th>
                        <th class="text-end">Threshold</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.LowStockProducts)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td><code>@p.SKU</code></td>
                            <td>@p.Category.Name</td>
                            <td class="text-end fw-bold text-danger">@p.StockQuantity</td>
                            <td class="text-end text-muted">@p.LowStockThreshold</td>
                            <td class="text-end">
                                <a asp-page="/Products/Edit" asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-primary">Restock</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        // ── Data from server ──
        const categoryLabels  = @Html.Raw(Model.CategoryLabelsJson);
        const stockData       = @Html.Raw(Model.CategoryStockJson);
        const productCountData= @Html.Raw(Model.CategoryProductCountJson);

        const palette = ['#0d6efd','#198754','#ffc107','#0dcaf0','#6610f2','#fd7e14'];

        // ── Bar: Stock by Category ──
        new Chart(document.getElementById('stockByCategoryChart'), {
        type: 'bar',
        data: {
        labels: categoryLabels,
        datasets: [{
        label: 'Units in Stock',
        data: stockData,
        backgroundColor: palette,
        borderRadius: 6,
        borderSkipped: false
        }]
        },
        options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
        y: { beginAtZero: true, ticks: { precision: 0 } }
        }
        }
        });

        // ── Doughnut: Products per Category ──
        new Chart(document.getElementById('productsByCategoryChart'), {
        type: 'doughnut',
        data: {
        labels: categoryLabels,
        datasets: [{
        data: productCountData,
        backgroundColor: palette,
        hoverOffset: 8
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { position: 'bottom' }
        },
        cutout: '60%'
        }
        });
    </script>
}