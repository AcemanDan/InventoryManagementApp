@page
@model InventoryManagement.Pages.Suppliers.IndexModel
@{
    ViewData["Title"] = "Suppliers";
}

<div class="page-header">
    <h1><i class="bi bi-truck me-2 text-primary"></i>Suppliers</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Supplier
    </a>
</div>

@if (Model.Suppliers.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Supplier</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-end">Products</th>
                        <th class="text-center">Status</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Suppliers)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:34px;height:34px;background:#f0f4ff;">
                                        <i class="bi bi-truck text-primary" style="font-size:.85rem"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@s.Name</div>
                                        @if (!string.IsNullOrEmpty(s.Address))
                                        {
                                            <div class="text-muted small text-truncate" style="max-width:200px">
                                                @s.Address
                                            </div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.Email))
                                {
                                    <a href="mailto:@s.Email" class="small text-decoration-none">@s.Email</a>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.Phone))
                                {
                                    <a href="tel:@s.Phone" class="small text-decoration-none">@s.Phone</a>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="/ProductPages/Index" asp-route-supplierId="@s.Id"
                                   class="text-decoration-none fw-semibold @(s.ProductCount == 0 ? "text-muted" : "")">
                                    @s.ProductCount
                                </a>
                            </td>
                            <td class="text-center">
                                @if (s.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-page="Edit" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-light border" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@s.Id"
                                       class="btn btn-sm btn-light border text-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-truck display-4 d-block mb-3 opacity-25"></i>
            <p class="fw-semibold mb-1">No suppliers yet</p>
            <p class="small mb-3">Add a supplier to link products to their source.</p>
            <a asp-page="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Supplier
            </a>
        </div>
    </div>
}
