@page
@model InventoryManagement.Pages.ProductPages.IndexModel

@{
    ViewData["Title"] = "Products";
}

<div class="page-header">
    <h1><i class="bi bi-box-seam me-2 text-primary"></i>Products</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Product
    </a>
</div>

<!-- ── Filters ────────────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label small text-muted mb-1">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="search" name="search" value="@Model.Search"
                           class="form-control border-start-0 bg-light"
                           placeholder="Name or SKU…" />
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Category</label>
                <select name="categoryId" class="form-select bg-light">
                    <option value="">All categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Value" selected="@(Model.CategoryId?.ToString() == c.Value)">
                            @c.Text
                        </option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Stock Status</label>
                <select name="stockFilter" class="form-select bg-light">
                    <option value="">All</option>
                    <option value="low" selected="@(Model.StockFilter == "low")">Low stock</option>
                    <option value="ok" selected="@(Model.StockFilter == "ok")">In stock</option>
                    <option value="zero" selected="@(Model.StockFilter == "zero")">Out of stock</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small text-muted mb-1">Sort by</label>
                <select name="sortBy" class="form-select bg-light">
                    <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                    <option value="stock" selected="@(Model.SortBy == "stock")">Stock ↑</option>
                    <option value="price" selected="@(Model.SortBy == "price")">Price</option>
                    <option value="date" selected="@(Model.SortBy == "date")">Newest</option>
                </select>
            </div>
            <div class="col-6 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary" title="Clear filters">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- ── Results summary ───────────────────────────────────────────────────── -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <p class="text-muted small mb-0">
        Showing <strong>@Model.Products.Count</strong> of <strong>@Model.TotalCount</strong> products
    </p>
</div>

<!-- ── Table ─────────────────────────────────────────────────────────────── -->
@if (Model.Products.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:36px"></th>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Stock</th>
                        <th class="text-center">Status</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Products)
                    {
                        <tr>
                            <td>
                                <div class="rounded-2 d-flex align-items-center justify-content-center"
                                     style="width:32px;height:32px;background:#f0f4ff;">
                                    <i class="bi bi-box text-primary" style="font-size:.85rem"></i>
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold">@p.Name</div>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <div class="text-muted small text-truncate" style="max-width:220px">
                                        @p.Description
                                    </div>
                                }
                            </td>
                            <td><code class="small">@(p.SKU ?? "—")</code></td>
                            <td>
                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary">
                                    @p.Category.Name
                                </span>
                            </td>
                            <td class="text-muted small">@(p.Supplier?.Name ?? "—")</td>
                            <td class="text-end fw-semibold">@p.Price.ToString("C")</td>
                            <td class="text-end">
                                <span class="fw-bold @(p.StockQuantity == 0 ? "text-danger" : p.IsLowStock ? "text-warning" : "text-success")">
                                    @p.StockQuantity
                                </span>
                            </td>
                            <td class="text-center">
                                @if (!p.IsActive)
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                                else if (p.StockQuantity == 0)
                                {
                                    <span class="badge bg-danger">Out of stock</span>
                                }
                                else if (p.IsLowStock)
                                {
                                    <span class="badge bg-warning text-dark">Low stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">In stock</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-page="Details" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-light border" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-page="Edit" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-light border" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-page="Delete" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-light border text-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Pagination ─────────────────────────────────────────────────────── -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4 d-flex justify-content-center" aria-label="Products pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-search="@Model.Search"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-stockFilter="@Model.StockFilter"
                       asp-route-sortBy="@Model.SortBy">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-page="Index"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-stockFilter="@Model.StockFilter"
                           asp-route-sortBy="@Model.SortBy">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-search="@Model.Search"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-stockFilter="@Model.StockFilter"
                       asp-route-sortBy="@Model.SortBy">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-box-seam display-4 d-block mb-3 opacity-25"></i>
            <p class="mb-1 fw-semibold">No products found</p>
            <p class="small mb-3">Try adjusting your filters or add a new product.</p>
            <a asp-page="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Product
            </a>
        </div>
    </div>
}
