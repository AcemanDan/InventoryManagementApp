@page
@model InventoryManagement.Pages.ProductPages.CreateModel

@{
    ViewData["Title"] = "Add Product";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a asp-page="Index">Products</a></li>
                <li class="breadcrumb-item active">Add Product</li>
            </ol>
        </nav>
        <h1>Add Product</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-4"></div>

            <!-- ── Core details ───────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Product Details</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Product.Name" class="form-label"></label>
                        <input asp-for="Product.Name" class="form-control" placeholder="e.g. Wireless Keyboard" />
                        <span asp-validation-for="Product.Name" class="text-danger small"></span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Product.SKU" class="form-label"></label>
                            <input asp-for="Product.SKU" class="form-control" placeholder="e.g. ELEC-001" />
                            <span asp-validation-for="Product.SKU" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.Price" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Product.Price" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Product.Price" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Product.Description" class="form-label"></label>
                        <textarea asp-for="Product.Description" class="form-control" rows="3"
                                  placeholder="Optional description…"></textarea>
                        <span asp-validation-for="Product.Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- ── Stock ──────────────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Stock Settings</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Product.StockQuantity" class="form-label"></label>
                            <input asp-for="Product.StockQuantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Product.StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.LowStockThreshold" class="form-label"></label>
                            <input asp-for="Product.LowStockThreshold" class="form-control" type="number" min="0" />
                            <div class="form-text">Alert triggers when stock falls to or below this number.</div>
                            <span asp-validation-for="Product.LowStockThreshold" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Classification ─────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Classification</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Product.CategoryId" class="form-label"></label>
                            <select asp-for="Product.CategoryId" asp-items="Model.CategoryList"
                                    class="form-select">
                                <option value="">— Select category —</option>
                            </select>
                            <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.SupplierId" class="form-label"></label>
                            <select asp-for="Product.SupplierId" asp-items="Model.SupplierList"
                                    class="form-select">
                                <option value="">— No supplier —</option>
                            </select>
                            <span asp-validation-for="Product.SupplierId" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3 form-check form-switch">
                        <input asp-for="Product.IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="Product.IsActive" class="form-check-label">Active (visible in inventory)</label>
                    </div>
                </div>
            </div>

            <!-- ── Actions ────────────────────────────────────────────────── -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Product
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <!-- ── Tips sidebar ──────────────────────────────────────────────────── -->
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Tips</div>
            <div class="card-body small text-muted">
                <p>
                    <i class="bi bi-info-circle text-primary me-1"></i>
                    <strong>SKU</strong> (Stock Keeping Unit) is your internal product code. Must be unique if provided.
                </p>
                <p>
                    <i class="bi bi-info-circle text-primary me-1"></i>
                    <strong>Low Stock Threshold</strong> triggers a warning on the dashboard when stock reaches this level. Default is 10.
                </p>
                <p class="mb-0">
                    <i class="bi bi-info-circle text-primary me-1"></i>
                    Setting a product to <strong>Inactive</strong> hides it from inventory counts without deleting it.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
