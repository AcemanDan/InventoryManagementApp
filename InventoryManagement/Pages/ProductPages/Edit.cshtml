@page "{id:int}"
@model InventoryManagement.Pages.ProductPages.EditModel

@{
    ViewData["Title"] = $"Edit — {Model.Product.Name}";
}

<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a asp-page="Index">Products</a></li>
                <li class="breadcrumb-item">
                    <a asp-page="Details" asp-route-id="@Model.Product.Id">@Model.Product.Name</a>
                </li>
                <li class="breadcrumb-item active">Edit</li>
            </ol>
        </nav>
        <h1>Edit Product</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <form method="post">
            <input type="hidden" asp-for="Product.Id" />
            <input type="hidden" asp-for="Product.DateAdded" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-4"></div>

            <!-- ── Core details ───────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Product Details</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Product.Name" class="form-label"></label>
                        <input asp-for="Product.Name" class="form-control" />
                        <span asp-validation-for="Product.Name" class="text-danger small"></span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Product.SKU" class="form-label"></label>
                            <input asp-for="Product.SKU" class="form-control" />
                            <span asp-validation-for="Product.SKU" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.Price" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Product.Price" class="form-control" />
                            </div>
                            <span asp-validation-for="Product.Price" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Product.Description" class="form-label"></label>
                        <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Product.Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- ── Stock ──────────────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold d-flex justify-content-between align-items-center">
                    Stock Settings
                    <a asp-page="Restock" asp-route-id="@Model.Product.Id" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-plus-lg me-1"></i> Log Stock Change
                    </a>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Product.StockQuantity" class="form-label"></label>
                            <input asp-for="Product.StockQuantity" class="form-control" type="number" min="0" />
                            <div class="form-text">
                                Use <a asp-page="Restock" asp-route-id="@Model.Product.Id">Log Stock Change</a>
                                to keep a transaction history.
                            </div>
                            <span asp-validation-for="Product.StockQuantity" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.LowStockThreshold" class="form-label"></label>
                            <input asp-for="Product.LowStockThreshold" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Product.LowStockThreshold" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Classification ─────────────────────────────────────────── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">Classification</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Product.CategoryId" class="form-label"></label>
                            <select asp-for="Product.CategoryId" asp-items="Model.CategoryList"
                                    class="form-select">
                                <option value="">— Select category —</option>
                            </select>
                            <span asp-validation-for="Product.CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Product.SupplierId" class="form-label"></label>
                            <select asp-for="Product.SupplierId" asp-items="Model.SupplierList"
                                    class="form-select">
                                <option value="">— No supplier —</option>
                            </select>
                            <span asp-validation-for="Product.SupplierId" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3 form-check form-switch">
                        <input asp-for="Product.IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="Product.IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a asp-page="Details" asp-route-id="@Model.Product.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>

    <!-- ── Meta sidebar ───────────────────────────────────────────────────── -->
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">Product Info</div>
            <div class="card-body small">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">ID</span>
                    <span class="fw-semibold">#@Model.Product.Id</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Date Added</span>
                    <span>@Model.Product.DateAdded.ToString("MMM d, yyyy")</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Last Updated</span>
                    <span>@Model.Product.LastUpdated.ToString("MMM d, yyyy")</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted">Transactions</span>
                    <a asp-page="Details" asp-route-id="@Model.Product.Id"
                       asp-fragment="transactions">View history</a>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a asp-page="Delete" asp-route-id="@Model.Product.Id"
               class="btn btn-outline-danger w-100 btn-sm">
                <i class="bi bi-trash me-1"></i> Delete this product
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
