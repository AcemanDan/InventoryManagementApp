@page
@model InventoryManagement.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<div class="page-header">
    <h1><i class="bi bi-gear me-2 text-primary"></i>Settings</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <form method="post">
            <input type="hidden" asp-for="Settings.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-4"></div>

            <!-- ── Company ── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-building me-2 text-primary"></i>Company
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Settings.CompanyName" class="form-label"></label>
                        <input asp-for="Settings.CompanyName" class="form-control"
                               placeholder="e.g. Acme Corp" />
                        <span asp-validation-for="Settings.CompanyName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Settings.CompanyAddress" class="form-label"></label>
                        <textarea asp-for="Settings.CompanyAddress" class="form-control" rows="2"
                                  placeholder="Optional company address"></textarea>
                        <span asp-validation-for="Settings.CompanyAddress" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Settings.ContactEmail" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Settings.ContactEmail" class="form-control"
                                   placeholder="contact@company.com" />
                        </div>
                        <span asp-validation-for="Settings.ContactEmail" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- ── Inventory ── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-boxes me-2 text-primary"></i>Inventory Defaults
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Settings.DefaultLowStockThreshold" class="form-label"></label>
                            <input asp-for="Settings.DefaultLowStockThreshold" class="form-control"
                                   type="number" min="1" max="10000" />
                            <div class="form-text">
                                Applied to new products as the default alert threshold.
                            </div>
                            <span asp-validation-for="Settings.DefaultLowStockThreshold" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Settings.ProductsPerPage" class="form-label"></label>
                            <input asp-for="Settings.ProductsPerPage" class="form-control"
                                   type="number" min="5" max="100" />
                            <div class="form-text">
                                Number of rows shown per page on the Products list.
                            </div>
                            <span asp-validation-for="Settings.ProductsPerPage" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3 d-flex flex-column gap-2">
                        <div class="form-check form-switch">
                            <input asp-for="Settings.ShowLowStockAlerts" class="form-check-input"
                                   type="checkbox" role="switch" />
                            <label asp-for="Settings.ShowLowStockAlerts" class="form-check-label">
                                Show low stock alerts on Dashboard
                            </label>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="Settings.ShowInactiveProducts" class="form-check-input"
                                   type="checkbox" role="switch" />
                            <label asp-for="Settings.ShowInactiveProducts" class="form-check-label">
                                Show inactive products in lists
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Currency ── -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="bi bi-currency-dollar me-2 text-primary"></i>Currency
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Settings.CurrencySymbol" class="form-label"></label>
                            <input asp-for="Settings.CurrencySymbol" class="form-control"
                                   placeholder="$" maxlength="10" />
                            <div class="form-text">Displayed next to prices (e.g. $, £, €).</div>
                            <span asp-validation-for="Settings.CurrencySymbol" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Settings.CurrencyCode" class="form-label"></label>
                            <input asp-for="Settings.CurrencyCode" class="form-control"
                                   placeholder="USD" maxlength="10" />
                            <div class="form-text">ISO code for reference (e.g. USD, GBP, EUR).</div>
                            <span asp-validation-for="Settings.CurrencyCode" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Actions ── -->
            <div class="d-flex gap-2 align-items-center">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Save Settings
                </button>
                <span class="text-muted small">
                    Last saved: @Model.Settings.LastUpdated.ToString("MMM d, yyyy h:mm tt")
                </span>
            </div>
        </form>
    </div>

    <!-- ── Info sidebar ── -->
    <div class="col-lg-4 mt-4 mt-lg-0">

        <!-- App info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold">Application Info</div>
            <div class="card-body small">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">App Version</span>
                    <span class="fw-semibold">1.0.0</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Framework</span>
                    <span>.NET 10 / Razor Pages</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Database</span>
                    <span>SQL Server LocalDB</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted">ORM</span>
                    <span>EF Core 10</span>
                </div>
            </div>
        </div>

        <!-- Database stats -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent fw-semibold">Database Stats</div>
            <div class="card-body small">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Products</span>
                    <span class="fw-semibold">@Model.Stats.ProductCount</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Categories</span>
                    <span class="fw-semibold">@Model.Stats.CategoryCount</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Suppliers</span>
                    <span class="fw-semibold">@Model.Stats.SupplierCount</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted">Transactions</span>
                    <span class="fw-semibold">@Model.Stats.TransactionCount</span>
                </div>
            </div>
        </div>

        <!-- Danger zone -->
        <div class="card border-0 shadow-sm border-danger">
            <div class="card-header bg-transparent fw-semibold text-danger">
                <i class="bi bi-exclamation-triangle me-1"></i> Danger Zone
            </div>
            <div class="card-body small">
                <p class="text-muted mb-3">
                    These actions are irreversible. Make sure you know what you are doing.
                </p>
                <form method="post" asp-page-handler="ClearTransactions"
                      onsubmit="return confirm('Delete ALL stock transactions? This cannot be undone.')">
                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 mb-2">
                        <i class="bi bi-trash me-1"></i> Clear All Transactions
                    </button>
                </form>
                <form method="post" asp-page-handler="ResetDatabase"
                      onsubmit="return confirm('Reset the entire database to seed data? ALL data will be lost.')">
                    <button type="submit" class="btn btn-danger btn-sm w-100">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Reset to Seed Data
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
